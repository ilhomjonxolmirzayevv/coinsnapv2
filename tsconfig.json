{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    // "bundler" o'rniga "node" yoki "nodenext" ishlatamiz, 
    // chunki server-side kodni kompilyatsiya qilyapmiz
    "moduleResolution": "node", 
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    // MUHIM: Server build qilishda bular false bo'lishi kerak
    "allowImportingTsExtensions": false, 
    "noEmit": false, 
    
    // Build natijasi qayerga tushishi
    "outDir": "./dist",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["server.ts", "src"],
  "exclude": ["node_modules", "dist"]
}
